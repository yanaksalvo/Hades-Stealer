{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": false,     
    "declarationMap": false,  
    "sourceMap": false,       
    "removeComments": true,   
    "emitDeclarationOnly": false 
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}